# Pipeline Configuration
PIPELINE_SCAN_TIMEOUT=120
PIPELINE_MAX_FILES=500

# Scanner Settings
SEMGRUP_RULES_PATH=./rules/semgrep/
TRIVY_SEVERITY=HIGH,CRITICAL
TRIVY_FORMAT=sarif
ZAP_SCAN_DEPTH=baseline

# Triage Settings
TRIAGE_MIN_SEVERITY=high
TRIAGE_DEDUP_ENABLED=true
TRIAGE_CWE_MAPPING_ENABLED=true

# Remediation Settings
REMEDIATION_DETERMINISTIC_ONLY=true
REMEDIATION_LLM_FALLBACK_TIMEOUT=5
REMEDIATION_MAX_FILES_PER_PR=10

# Validation Settings
VALIDATION_RUN_TESTS=true
VALIDATION_RUN_LINTER=true
VALIDATION_RUN_RESCAN=true
VALIDATION_RESCAN_SEVERITY=high

# GitHub Settings (injected via secrets in CI)
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_PR_LABELS=security,auto-remediation

# OPA Settings
OPA_POLICY_PATH=./policies/
OPA_EVALUATION_TIMEOUT=10

# Database Settings
DATABASE_URL=postgres://devsecops:devsecops@localhost:5432/devsecops?sslmode=disable
DATABASE_MAX_CONNS=10

# API Server Settings
API_PORT=8080
API_LOG_LEVEL=info
API_CORS_ORIGINS=http://localhost:3000

# Frontend Settings
NEXT_PUBLIC_API_URL=http://localhost:8080
